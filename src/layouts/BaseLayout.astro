---
import { siteMetadata } from '@/metadata';

import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/style.scss';

const { mainClass = '' } = Astro.props;
// 末尾のスラッシュ削除（ただしルートパスは除く）
const normalizePath = (p?: string) => {
    if (!p) return '/';
    if (p === '/') return '/';
    return p.replace(/\/+$/, '');
};

const normalizedPage = normalizePath(Astro.url.pathname);
const pageMetadata = siteMetadata[normalizedPage] ?? siteMetadata['/'];
---

<html>
    <head>
        <BaseHead metadata={pageMetadata} />
    </head>
    <body>
        <Header />
        <main class:list={['container', mainClass]}>
            <slot />
        </main>
        <Footer />
    </body>
</html>
