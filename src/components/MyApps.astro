---
import { APPS } from '@/domain/app/registry';
import type { AppConfig } from '@/domain/app/types';
import App from './App.astro';
---

<section class="my-apps">
    <h2 class="my-apps__title">わたしがつくったアプリたち</h2>
    <ul class="my-apps__list app-list">
        {Object.values(APPS).map((app: AppConfig) => <App app={app} />)}
    </ul>
</section>
