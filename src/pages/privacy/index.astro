---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { APPS } from '@/domain/app/registry';

const privacyApps = Object.values(APPS).filter(
    (app) => app.privacyKind !== undefined,
);
---

<BaseLayout mainClass="legal">
    <h2 class="legal__title">プライバシーポリシー</h2>

    <section class="legal__section">
        <p class="legal__explanation">
            各アプリケーションのプライバシーポリシーは、以下よりご確認ください。
        </p>
    </section>

    <section class="legal__section">
        <ul class="legal__list legal__list--style-none">
            {
                privacyApps.map((app) => (
                    <li class="legal__item legal__item--app">
                        <span class="legal__app-name">{app.name.ja}</span>
                        <span class="legal__lang-links">
                            <a
                                class="legal__link"
                                href={`/privacy/${app.id}/ja`}
                            >
                                JA
                            </a>
                            <span class="legal__separator">|</span>
                            <a
                                class="legal__link"
                                href={`/privacy/${app.id}/en`}
                            >
                                EN
                            </a>
                        </span>
                    </li>
                ))
            }
        </ul>
    </section>
</BaseLayout>
