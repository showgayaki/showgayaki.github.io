---
import LegalTemplate from '@/components/legal/LegalTemplate.astro';
import ja from '@/i18n/privacy/ja';
import en from '@/i18n/privacy/en';

type Props = { lang: string };

export function getStaticPaths() {
  return [
    { params: { lang: 'ja' } },
    { params: { lang: 'en' } }
  ];
}

const page = Astro.params.lang ? `/privacy/${Astro.params.lang}` : "/privacy";
const lang = Astro.params.lang;
const dict = lang === 'en' ? en : ja;
---

<LegalTemplate page={page} dict={dict} />
