---
import LegalTemplate from '@/components/legal/LegalTemplate.astro';

import { buildPaths } from '@/domain/app/paths';
import { APPS } from '@/domain/app/registry';
import type { AppId, Lang } from '@/domain/app/types';
import type { LegalDict } from '@/components/legal/LegalTemplate.astro';

// i18n
import calendarJa from '@/i18n/terms/70-calendar/ja';
import calendarEn from '@/i18n/terms/70-calendar/en';

export function getStaticPaths() {
    return buildPaths('terms');
}

type Props = { app: string; lang: string };

const routeParams = Astro.params as Partial<{ app: AppId; lang: Lang }>;
const props = Astro.props as Partial<{ app: AppId; lang: Lang }>;

const app = (routeParams.app ?? props.app) as AppId;
const lang = (routeParams.lang ?? props.lang) as Lang;

const appConfig = APPS[app];
const appName = appConfig.name[lang];

let dict: LegalDict | undefined;
switch (appConfig.termsKind) {
    case '70-calendar':
        dict = lang === 'en' ? calendarEn : calendarJa;
        break;

    default:
        throw new Error(`Unknown terms kind for app: ${app}`);
}

if (!dict) {
    throw new Error(`Unknown app or lang: ${app}/${lang}`);
}
---

<LegalTemplate dict={dict} />
